# Apache — SPA fallback for React Router (BrowserRouter)
# Vite copies public/.htaccess → dist/.htaccess on build

Options -MultiViews
RewriteEngine On
RewriteBase /
DirectoryIndex index.html

# Canonical root URL
RewriteRule ^index\.html$ / [R=301,L,NC]
RewriteRule ^index$ / [R=301,L,NC]

# Remove trailing slash (except root) so relative assets stay stable
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L]

# Redirect legacy .html URLs to clean SPA paths
RewriteCond %{THE_REQUEST} \s/+([^.]+)\.html(?:[\s?]|$) [NC]
RewriteRule ^([^.]+)\.html$ /$1 [R=301,L,NC]

# Existing files/dirs (assets, images, js, etc.) — serve as-is
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# SPA fallback: every other path → index.html (React Router handles it)
RewriteRule ^ index.html [L]

# Enable compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# Enable browser caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
</IfModule>
